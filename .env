# .env
DATABASE_URL=postgres://myuser:mypassword@localhost/myahp
APP_ORIGIN=http://127.0.0.1:8000  # For CORS and external reference
BIND_ADDRESS=127.0.0.1:8000      # For TcpListener::bind
JWT_SECRET=your_jwt_secret_key

SMTP_HOST=your.host
SMTP_USERNAME=api
SMTP_PASSWORD=password_for_smtp
SMTP_PORT=587
SMTP_FROM_NO_REPLY=email@domain.changed
